# Music Matters — Environment Variables
# Copy this file to .env and edit as needed
# Most values have sensible defaults — you only need to set what you want to override

# ── Backend ──────────────────────────────────────────────────────────────────
PORT=8010
HOST=0.0.0.0
DEBUG=true

# ── Storage paths ─────────────────────────────────────────────────────────────
# Where your library database lives
# MUSIC_MATTERS_DATA_DIR=./data

# Where uploaded/ingested tracks are stored
# MUSIC_MATTERS_LIBRARY_DIR=./data/library

# Where stem separation outputs go
# MUSIC_MATTERS_STEMS_DIR=./data/stems

# MLX volume (if you have /Volumes/MLX set up — point model cache here)
# HF_HOME=/Volumes/MLX/hf-cache
# TRANSFORMERS_CACHE=/Volumes/MLX/hf-cache

# ── Demucs / Stem separation ──────────────────────────────────────────────────
# Model to use: htdemucs | htdemucs_ft | htdemucs_6s
# DEMUCS_MODEL=htdemucs_ft

# ── Optional: yt-dlp cookies for age-restricted content ───────────────────────
# YT_COOKIES_FILE=~/.config/yt-dlp/cookies.txt
